# ── Proxy data (never commit captured traffic or certs) ──
proxy_data/
*.db
*.db-shm
*.db-wal

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual environments ──────────────────────────────────
venv/
.venv/
env/
.env/

# ── mitmproxy certs (auto-generated, never commit) ───────
*.pem
*.cer
*.p12
*.pfx
~/.mitmproxy/

# ── Exports (generated output) ───────────────────────────
*.har
*.csv
report*.json

# ── OS & editor ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~
